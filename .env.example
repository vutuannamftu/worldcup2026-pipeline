# API-Football (API-SPORTS)
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# Football-data.org
FOOTBALL_DATA_API_KEY=your_api_key_here

# Project database (queryable data, Gold layer)
PROJECT_DB_NAME=worldcup2026
PROJECT_DB_USER=postgres
PROJECT_DB_PASSWORD=your_password_here

# Airflow metadata database
AIRFLOW_DB_PASSWORD=your_password_here

# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your_password_here

# VPS
VPS_HOST=your_vps_ip_here
VPS_USER=your_vps_user_here
